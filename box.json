{
	"name" 		: "OriginGuard",
	"version"   : "1.0.0",
	"location"  : "forgeboxStorage",
	"author" 	: "Angry Sam Productions, Inc.",
	"homepage"	: "https://github.com/homestar9/originguard",
	"documentation"		: "https://github.com/homestar9/originguard",
	"repository"		: { "type" : "git", "url" : "https://github.com/homestar9/originguard" },
	"bugs" : "https://github.com/homestar9/originguard/issues",
	"shortDescription"	: "Header-based cross-origin (CSRF) protection for ColdBox apps using the browser's Sec-Fetch-Site and Origin headers. No tokens, no sessions.",
	"slug"		: "originguard",
	"type"		: "modules",
	"keywords":"csrf,security,cross-origin,sec-fetch-site,origin,coldbox,interceptor",
	"license"			: [
		{ "type" : "Apache2", "url" : "http://www.apache.org/licenses/LICENSE-2.0.html" }
	],
	"contributors"		: [
	],
	"dependencies" 	:{
	},
	"devDependencies" 	:{
		"commandbox-boxlang":"*",
		"commandbox-cfformat":"*",
        "commandbox-docbox":"*"
	},
	"ignore":[
        "**/.*",
        "test-harness",
		"/server*.json",
		"plans",
		"docs",
		"AGENTS.md",
		"CLAUDE.md"
    ],
	"scripts":{
		"build:module":"task run taskFile=build/Build.cfc :projectName=`package show slug` :version=`package show version`",
		"build:docs":"task run taskFile=build/Build.cfc target=docs :projectName=`package show slug` :version=`package show version`",
        "install:dependencies":"install && cd test-harness && install",
		"release":"recipe build/release.boxr",
        "format":"cfformat run models,interceptors,handlers,test-harness/tests/,ModuleConfig.cfc --overwrite",
        "format:watch":"cfformat watch models,interceptors,handlers,test-harness/tests/,ModuleConfig.cfc ./.cfformat.json",
        "format:check":"cfformat check models,interceptors,handlers,test-harness/tests/,ModuleConfig.cfc ./.cfformat.json",
		"start:lucee5" : "server start serverConfigFile=server-lucee@5.json",
		"start:lucee6" : "server start serverConfigFile=server-lucee@6.json",
		"start:2023" : "server start serverConfigFile=server-adobe@2023.json",
		"start:2025" : "server start serverConfigFile=server-adobe@2025.json",
		"start:boxlang" : "server start serverConfigFile=server-boxlang@1.json",
		"start:boxlang-cfml" : "server start serverConfigFile=server-boxlang-cfml@1.json",
		"stop:lucee5" : "server stop serverConfigFile=server-lucee@5.json",
		"stop:lucee6" : "server stop serverConfigFile=server-lucee@6.json",
		"stop:2023" : "server stop serverConfigFile=server-adobe@2023.json",
		"stop:2025" : "server stop serverConfigFile=server-adobe@2025.json",
		"stop:boxlang" : "server stop serverConfigFile=server-boxlang@1.json",
		"stop:boxlang-cfml" : "server stop serverConfigFile=server-boxlang-cfml@1.json",
		"logs:lucee5" : "server log serverConfigFile=server-lucee@5.json --follow",
		"logs:lucee6" : "server log serverConfigFile=server-lucee@6.json --follow",
		"logs:2023" : "server log serverConfigFile=server-adobe@2023.json --follow",
		"logs:2025" : "server log serverConfigFile=server-adobe@2025.json --follow",
		"logs:boxlang" : "server log serverConfigFile=server-boxlang@1.json --follow",
		"logs:boxlang-cfml" : "server log serverConfigFile=server-boxlang-cfml@1.json --follow",
		"forget:lucee5" : "server forget serverConfigFile=server-lucee@5.json --force",
		"forget:lucee6" : "server forget serverConfigFile=server-lucee@6.json --force",
		"forget:2023" : "server forget serverConfigFile=server-adobe@2023.json --force",
		"forget:2025" : "server forget serverConfigFile=server-adobe@2025.json --force",
		"forget:boxlang" : "server forget serverConfigFile=server-boxlang@1.json --force",
		"forget:boxlang-cfml" : "server forget serverConfigFile=server-boxlang-cfml@1.json --force"
    },
	"testbox":{
        "runner":"http://localhost:60299/tests/runner.cfm"
    }
}
